{
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },
  "edit_predictions": {
    "mode": "eager",
    "provider": "copilot",
  },
  "agent_servers": {
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"],
    },
  },
  "colorize_brackets": true,
  "vim": {
    "use_smartcase_find": true,
  },
  "git_panel": {
    "dock": "right",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "scrollbar": {
    "diagnostics": "all",
  },
  "toolbar": {
    "code_actions": true,
    "breadcrumbs": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "minimap": { "show": "always" },
  "icon_theme": "Catppuccin Macchiato",
  "agent": {
    "show_turn_stats": true,
    "play_sound_when_agent_done": "always",
    "button": true,
    "dock": "right",
    "enabled": true,
  },
  "soft_wrap": "editor_width",
  "show_wrap_guides": true,
  "vim_mode": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "inlay_hints": {
    "enabled": true,
  },
  "tab_bar": {
    "show": true,
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "terminal": {
    "shell": {
      "program": "/usr/bin/fish",
    },
  },
  "outline_panel": {
    "button": true,
    "default_width": 240,
    "dock": "right",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "indent_guides": {
      "show": "always",
    },
    "scrollbar": {
      "show": "auto",
    },
  },
  "restore_on_startup": "last_session",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "Hack Nerd Font",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Macchiato (Blur) [Light]",
    "dark": "Catppuccin Mocha (Blur)",
  },
}
